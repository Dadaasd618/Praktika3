<UserControl x:Class="TechnologistModule.Controls.ReportsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Отчеты" FontSize="22" FontWeight="Bold" 
                   Foreground="#1E293B" Margin="15,10,0,10"/>

        <TabControl Grid.Row="1" Margin="10,0,10,10">
            <!-- Отчет по партиям -->
            <TabItem Header="По партиям">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center"/>
                        <DatePicker x:Name="BatchDateFrom" Width="120" Margin="10,0,10,0"/>
                        <TextBlock Text=" - " VerticalAlignment="Center"/>
                        <DatePicker x:Name="BatchDateTo" Width="120" Margin="10,0,10,0"/>
                        <Button Content="Сформировать" Width="110" Click="GenerateBatchReport_Click"/>
                        <Button Content="📎 Excel" Width="80" Margin="10,0,0,0" Click="ExportBatchToExcel_Click"/>
                        <Button Content="📄 CSV" Width="80" Margin="5,0,0,0" Click="ExportBatchToCsv_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="BatchReportGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" RowHeight="40" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Отчет по отклонениям -->
            <TabItem Header="По отклонениям">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Период:" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DeviationDateFrom" Width="120" Margin="10,0,10,0"/>
                        <TextBlock Text=" - " VerticalAlignment="Center"/>
                        <DatePicker x:Name="DeviationDateTo" Width="120" Margin="10,0,10,0"/>
                        <Button Content="Сформировать" Width="110" Click="GenerateDeviationReport_Click"/>
                        <Button Content="📎 Excel" Width="80" Margin="10,0,0,0" Click="ExportDeviationToExcel_Click"/>
                        <Button Content="📄 CSV" Width="80" Margin="5,0,0,0" Click="ExportDeviationToCsv_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="DeviationReportGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" RowHeight="40" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Отчет по использованию рецептур -->
            <TabItem Header="По рецептурам">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Сформировать" Width="110" Click="GenerateRecipeReport_Click"/>
                        <Button Content="📎 Excel" Width="80" Margin="10,0,0,0" Click="ExportRecipeToExcel_Click"/>
                        <Button Content="📄 CSV" Width="80" Margin="5,0,0,0" Click="ExportRecipeToCsv_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="RecipeReportGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" RowHeight="40" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Отчет по событиям экструдера -->
            <TabItem Header="По экструдеру">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Сформировать" Width="110" Click="GenerateExtruderReport_Click"/>
                        <Button Content="📎 Excel" Width="80" Margin="10,0,0,0" Click="ExportExtruderToExcel_Click"/>
                        <Button Content="📄 CSV" Width="80" Margin="5,0,0,0" Click="ExportExtruderToCsv_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="ExtruderReportGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" RowHeight="40" FontSize="12"/>
                </Grid>
            </TabItem>

            <!-- Отчет по лабораторным блокировкам -->
            <TabItem Header="По блокировкам">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Сформировать" Width="110" Click="GenerateBlockReport_Click"/>
                        <Button Content="📎 Excel" Width="80" Margin="10,0,0,0" Click="ExportBlockToExcel_Click"/>
                        <Button Content="📄 CSV" Width="80" Margin="5,0,0,0" Click="ExportBlockToCsv_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="BlockReportGrid" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" RowHeight="40" FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>