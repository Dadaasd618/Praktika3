<UserControl x:Class="LaboratoryModule.Views.ProtocolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Decision}" Value="approved">
                    <Setter Property="Background" Value="#10B981"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Decision}" Value="blocked">
                    <Setter Property="Background" Value="#EF4444"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="pending">
                    <Setter Property="Background" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="testing">
                    <Setter Property="Background" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="quality_control">
                    <Setter Property="Background" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="completed">
                    <Setter Property="Background" Value="#10B981"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="created">
                    <Setter Property="Background" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="in_progress">
                    <Setter Property="Background" Value="#3B82F6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="planned">
                    <Setter Property="Background" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="running">
                    <Setter Property="Background" Value="#3B82F6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3B82F6" CornerRadius="10" Padding="15,12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📄 Протоколы испытаний" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Архив завершённых испытаний" FontSize="12" Foreground="#BFDBFE" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="10" Padding="12" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Height="35" Style="{StaticResource ModernTextBox}" 
                         TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center"/>

                <ComboBox x:Name="TypeFilter" Grid.Column="1" Width="130" Height="35" Margin="10,0,0,0"
                          Style="{StaticResource ModernComboBox}" SelectionChanged="TypeFilter_SelectionChanged">
                    <ComboBoxItem Content="Все типы" IsSelected="True"/>
                    <ComboBoxItem Content="raw_material"/>
                    <ComboBoxItem Content="product"/>
                </ComboBox>

                <ComboBox x:Name="DecisionFilter" Grid.Column="2" Width="120" Height="35" Margin="10,0,0,0"
                          Style="{StaticResource ModernComboBox}" SelectionChanged="DecisionFilter_SelectionChanged">
                    <ComboBoxItem Content="Все решения" IsSelected="True"/>
                    <ComboBoxItem Content="approved"/>
                    <ComboBoxItem Content="blocked"/>
                </ComboBox>

                <DatePicker x:Name="DateFrom" Grid.Column="3" Width="110" Height="35" Margin="10,0,0,0"
                            SelectedDateChanged="DateFrom_SelectedDateChanged"/>
                <TextBlock Grid.Column="4" Text="—" VerticalAlignment="Center" Margin="8,0" FontSize="14" Foreground="#64748B"/>
                <DatePicker x:Name="DateTo" Grid.Column="5" Width="110" Height="35" Margin="0,0,0,0"
                            SelectedDateChanged="DateTo_SelectedDateChanged"/>
            </Grid>
        </Border>

        <DataGrid x:Name="ProtocolsGrid" Grid.Row="2" 
                  Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionChanged="ProtocolsGrid_SelectionChanged"
                  RowHeight="45"
                  FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ протокола" Binding="{Binding TestNumber}" Width="110" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Тип объекта" Binding="{Binding ObjectType}" Width="110"/>
                <DataGridTextColumn Header="Объект" Binding="{Binding ObjectName}" Width="200"/>
                <DataGridTextColumn Header="Тип испытания" Binding="{Binding TestType}" Width="120"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding TestedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                <DataGridTextColumn Header="Исполнитель" Binding="{Binding TestedByName}" Width="150"/>
                <DataGridTemplateColumn Header="Решение" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusBorderStyle}">
                                <TextBlock Text="{Binding Decision}" Foreground="White" FontSize="11" 
                                           FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📄" ToolTip="Просмотр протокола" Style="{StaticResource SecondaryButton}" 
                                    Click="ViewProtocol_Click" Tag="{Binding}" Width="30" Height="30" FontSize="14"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>