<UserControl x:Class="TechnologistModule.Controls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📊 Панель управления" FontSize="24" FontWeight="Bold" 
                   Foreground="#1E293B" Margin="0,0,0,20"/>

        <!-- KPI карточки -->
        <UniformGrid Grid.Row="1" Columns="4" Rows="2" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Активных продуктов" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="ActiveProductsCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Действующих рецептур" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="ActiveRecipesCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Действующих техкарт" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="ActiveTechCardsCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#1E293B"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Заказов в работе" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="OrdersInProgressCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Партий в производстве" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="BatchesInProgressCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#3B82F6"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Партий с отклонениями" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="BatchesWithDeviationsCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#EF4444"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="12" Margin="5">
                <StackPanel>
                    <TextBlock Text="Ожидают лабораторию" Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="BatchesAwaitingLabCount" Text="0" FontSize="28" 
                               FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- События и партии на анализ -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 Последние события" FontSize="16" FontWeight="Bold" 
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <ListBox x:Name="RecentEventsList" Grid.Row="1" BorderThickness="0" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Description}" 
                                                   FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"/>
                                        <TextBlock Text="{Binding Timestamp}" 
                                                   Foreground="#94A3B8" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="16" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚠️ Партии, требующие анализа" FontSize="16" FontWeight="Bold" 
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <ListBox x:Name="BatchesForAnalysisList" Grid.Row="1" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding BatchNumber}" 
                                                   FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>