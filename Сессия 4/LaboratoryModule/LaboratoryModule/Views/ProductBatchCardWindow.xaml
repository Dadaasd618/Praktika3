<Window x:Class="LaboratoryModule.Views.ProductBatchCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка партии готовой продукции" Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="planned">
                    <Setter Property="Background" Value="#94A3B8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="running">
                    <Setter Property="Background" Value="#3B82F6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="quality_control">
                    <Setter Property="Background" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="approved">
                    <Setter Property="Background" Value="#10B981"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="blocked">
                    <Setter Property="Background" Value="#EF4444"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="completed">
                    <Setter Property="Background" Value="#10B981"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3B82F6" CornerRadius="10" Padding="12" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" Text="🏭 Карточка партии готовой продукции" FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Основная информация -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Номер партии:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="BatchNumberText" Grid.Column="1" Foreground="#1E293B" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Количество (кг):" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="QuantityText" Grid.Column="3" Foreground="#1E293B"/>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Продукт:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="ProductNameText" Grid.Column="1" Foreground="#1E293B" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Статус:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <Border x:Name="StatusBorder" Grid.Column="3" Style="{StaticResource StatusBorderStyle}">
                        <TextBlock x:Name="StatusText" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Заказ:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="OrderNumberText" Grid.Column="1" Foreground="#1E293B" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Время запуска:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="StartTimeText" Grid.Column="3" Foreground="#1E293B"/>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Версия рецептуры:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="RecipeVersionText" Grid.Column="1" Foreground="#1E293B" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Техкарта:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="TechCardText" Grid.Column="3" Foreground="#1E293B"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Испытания -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="📋 Испытания" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                    <Button Grid.Column="1" Content="🔄" Width="30" Height="30" 
                            Style="{StaticResource SecondaryButton}" Click="RefreshTests_Click" ToolTip="Обновить список"/>
                    <Button Grid.Column="2" Content="➕ Новое испытание" Width="130" Height="30" Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}" Click="NewTest_Click" FontSize="12"/>
                </Grid>

                <DataGrid x:Name="TestsGrid" Grid.Row="1" 
          Style="{StaticResource ModernDataGrid}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          SelectionChanged="TestsGrid_SelectionChanged"
          MinHeight="100"
          MaxHeight="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ испытания" Binding="{Binding TestNumber}" Width="100"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding TestType}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Исполнитель" Binding="{Binding TestedByName}" Width="130"/>
                        <DataGridTemplateColumn Header="Статус" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="5,2" 
                                            Background="#94A3B8" Width="75" Height="24" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Лабораторное решение -->
        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🔬 Лабораторное решение" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Текущий статус:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="CurrentStatusText" Grid.Column="1" Foreground="#1E293B" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Дата решения:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="DecisionDateText" Grid.Column="3" Foreground="#1E293B"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Принял решение:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="DecisionByText" Grid.Column="1" Foreground="#1E293B"/>
                </Grid>

                <StackPanel Grid.Row="3" Margin="0,5,0,0">
                    <TextBlock Text="Комментарий / Причина:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                    <TextBox x:Name="DecisionCommentBox" Height="50" TextWrapping="Wrap" IsEnabled="False"
                             Style="{StaticResource ModernTextBox}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Закрыть" Width="100" Height="35" Style="{StaticResource SecondaryButton}" Click="Close_Click"/>
            <Button x:Name="DecisionButton" Content="Принять решение" Width="130" Height="35" Margin="10,0,0,0"
                    Style="{StaticResource PrimaryButton}" Click="MakeDecision_Click"/>
        </StackPanel>
    </Grid>
</Window>