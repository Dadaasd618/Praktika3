<Window x:Class="TechnologistModule.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnologistModule.Views"
        mc:Ignorable="d"
     
        Title="АгроКонтроль - Технолог" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#1E293B">
            <StackPanel>
                <!-- Профиль с аватаркой -->
                <Border Background="#0F172A" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Аватарка с возможностью загрузки -->
                        <Border Width="64" Height="64" Background="#3B82F6" CornerRadius="32" 
                                HorizontalAlignment="Left" Margin="0,0,0,10"
                                Cursor="Hand" MouseLeftButtonDown="Avatar_Click">
                            <Image x:Name="UserAvatar" Width="64" Height="64" 
                                   Stretch="UniformToFill" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="UserFullName" Text="Иванов И.П." 
                                   FontWeight="Bold" Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="UserRole" Text="Технолог" 
                                   Foreground="#94A3B8" FontSize="12"/>
                        <TextBlock x:Name="UserDepartment" Text="Технологический отдел" 
                                   Foreground="#64748B" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Меню -->
                <StackPanel Margin="0,0,0,20">
                    <Button x:Name="HomeButton" Content="🏠 Главная" 
                            Style="{StaticResource SideMenuButton}" Click="HomeButton_Click"/>
                    <Button x:Name="ProductsButton" Content="📦 Продукция" 
                            Style="{StaticResource SideMenuButton}" Click="ProductsButton_Click"/>
                    <Button x:Name="RecipesButton" Content="📋 Рецептуры" 
                            Style="{StaticResource SideMenuButton}" Click="RecipesButton_Click"/>
                    <Button x:Name="TechCardsButton" Content="⚙️ Технологические карты" 
                            Style="{StaticResource SideMenuButton}" Click="TechCardsButton_Click"/>
                    <Button x:Name="OrdersButton" Content="📄 Производственные заказы" 
                            Style="{StaticResource SideMenuButton}" Click="OrdersButton_Click"/>
                    <Button x:Name="BatchesButton" Content="🏭 Производственные партии" 
                            Style="{StaticResource SideMenuButton}" Click="BatchesButton_Click"/>
                    <Button x:Name="ExtruderButton" Content="🔧 Программы экструдера" 
                            Style="{StaticResource SideMenuButton}" Click="ExtruderButton_Click"/>
                    <Button x:Name="EventsButton" Content="⚠️ Отклонения и события" 
                            Style="{StaticResource SideMenuButton}" Click="EventsButton_Click"/>
                    <Button x:Name="ReportsButton" Content="📊 Отчеты" 
                            Style="{StaticResource SideMenuButton}" Click="ReportsButton_Click"/>
                </StackPanel>

                <!-- Выход -->
                <Button x:Name="LogoutButton" Content="🚪 Выход" 
                        Style="{StaticResource SideMenuButton}" Click="LogoutButton_Click" Margin="0,50,0,0"/>
            </StackPanel>
        </Border>

        <!-- Область контента (меняется при клике) -->
        <ContentControl x:Name="ContentArea" Grid.Column="1" Margin="20"/>
    </Grid>
</Window>
