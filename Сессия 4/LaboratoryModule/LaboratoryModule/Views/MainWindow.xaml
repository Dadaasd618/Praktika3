<Window x:Class="LaboratoryModule.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Лаборатория" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <LinearGradientBrush x:Key="MenuGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E293B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="ContentShadow" ShadowDepth="0" BlurRadius="15" Opacity="0.08"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Width="48" Height="48" Background="#3B82F6" CornerRadius="24" 
        HorizontalAlignment="Left" Margin="0,0,0,10"
        Cursor="Hand" MouseLeftButtonDown="Avatar_Click">
         
        </Border>
        <!-- Боковое меню с градиентом -->
        <Border Grid.Column="0" Background="#1E293B">
            <StackPanel>
                <!-- Профиль с фото -->
                <Border Background="#0F172A" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Аватарка -->
                        <Border Width="64" Height="64" Background="#3B82F6" CornerRadius="32" 
                        HorizontalAlignment="Center" Margin="0,0,0,10"
                        Cursor="Hand" MouseLeftButtonDown="Avatar_Click">
                            <Image x:Name="UserAvatar" Width="64" Height="64" 
                           Stretch="UniformToFill" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- ФИО -->
                        <TextBlock x:Name="UserFullName" Text="Васильева Е.А." 
                           FontWeight="Bold" Foreground="White" FontSize="14" 
                           HorizontalAlignment="Center"/>
                        <!-- Роль -->
                        <TextBlock x:Name="UserRole" Text="Лаборант" 
                           Foreground="#94A3B8" FontSize="12" 
                           HorizontalAlignment="Center"/>
                        <!-- Подразделение -->
                        <TextBlock x:Name="UserDepartment" Text="Лаборатория контроля качества" 
                           Foreground="#64748B" FontSize="11" 
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Меню -->
                <StackPanel Margin="0,0,0,20">
                    <Button x:Name="RawMaterialBatchesButton" Content="📦 Партии сырья" 
                    Style="{StaticResource SideMenuButton}" Click="RawMaterialBatchesButton_Click"/>
                    <Button x:Name="ProductBatchesButton" Content="🏭 Готовая продукция" 
                    Style="{StaticResource SideMenuButton}" Click="ProductBatchesButton_Click"/>
                    <Button x:Name="ProtocolsButton" Content="📄 Протоколы испытаний" 
                    Style="{StaticResource SideMenuButton}" Click="ProtocolsButton_Click"/>
                </StackPanel>

                <!-- Выход -->
                <Button x:Name="LogoutButton" Content="🚪 Выход" 
                Style="{StaticResource SideMenuButton}" Click="LogoutButton_Click" Margin="0,50,0,0"/>
            </StackPanel>
        </Border>

        <!-- Область контента -->
        <Border Grid.Column="1" Margin="20" Background="White" CornerRadius="20" Effect="{StaticResource ContentShadow}">
            <ContentControl x:Name="ContentArea" Margin="5"/>
        </Border>
    </Grid>
</Window>