<UserControl x:Class="OperatorModule.Views.BatchProgramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" Height="605" Width="784">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка партии с выбором -->
        <Border Grid.Row="0" Background="#3B82F6" CornerRadius="12" Padding="15,12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Программа партии" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Партия:" Foreground="#BFDBFE" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="BatchCombo" Width="200" Height="32" 
                              Style="{StaticResource ModernComboBox}" 
                              SelectionChanged="BatchCombo_SelectionChanged"
                              DisplayMemberPath="BatchNumber" SelectedValuePath="Id"/>
                </StackPanel>

                <Button Grid.Column="2" Content="🔄" Width="45" Height="40" 
                        Style="{StaticResource SecondaryButton}" Click="Refresh_Click" FontSize="14"/>
            </Grid>
        </Border>

        <!-- Информация о партии -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="BatchNumberText" Text="Партия: B-2401-01" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                <TextBlock x:Name="ProductNameText" Text=" | Продукт: Гербицид А" FontSize="14" Foreground="#1E293B" Margin="15,0,0,0"/>
                <TextBlock x:Name="LineText" Text=" | Линия: L-01" FontSize="14" Foreground="#1E293B" Margin="15,0,0,0"/>
                <Border x:Name="StatusIndicator" Width="12" Height="12" CornerRadius="6" Background="#10B981" Margin="15,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="В работе" FontSize="14" Foreground="#1E293B"/>
            </StackPanel>
        </Border>

        <!-- Основная область (шаги слева, рабочая зона справа) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список шагов -->
            <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="12" Padding="10" Margin="0,0,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📋 Шаги технологической карты" FontSize="14" FontWeight="Bold" 
                               Foreground="#1E293B" Margin="0,0,0,10"/>

                    <ListBox x:Name="StepsList" Grid.Row="1" BorderThickness="0" 
                             SelectionChanged="StepsList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="10,8" Margin="0,0,0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="StepStatusIndicator" Width="10" Height="10" CornerRadius="5" 
                                                Background="#94A3B8" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding StepName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding StepType}" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>

                                        <Border x:Name="DeviationIndicator" Grid.Column="2" 
                                                Width="20" Height="20" CornerRadius="10" Background="Transparent"
                                                Visibility="Collapsed">
                                            <TextBlock Text="⚠️" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="completed">
                                        <Setter TargetName="StepStatusIndicator" Property="Background" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="in_progress">
                                        <Setter TargetName="StepStatusIndicator" Property="Background" Value="#3B82F6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="pending">
                                        <Setter TargetName="StepStatusIndicator" Property="Background" Value="#94A3B8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DeviationFlag}" Value="true">
                                        <Setter TargetName="DeviationIndicator" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Рабочая зона шага -->
            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="StepNameTitle" Text="Шаг: Экструзия" FontSize="18" FontWeight="Bold" 
                               Foreground="#1E293B" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Тип:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="StepTypeText" Text="Экструзия" Grid.ColumnSpan="2" Margin="70,0,30,0"/>
                        <TextBlock Grid.Column="2" Text="Статус:" FontWeight="SemiBold" Foreground="#64748B"/>
                        <TextBlock x:Name="StepStatusText" Grid.Column="2" Text="Не начат" Grid.ColumnSpan="2" Margin="90,0,10,0"/>
                    </Grid>

                    <Border Grid.Row="2" Background="#EFF6FF" CornerRadius="10" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📖 Инструкция:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                            <TextBlock x:Name="InstructionText" TextWrapping="Wrap" FontSize="13" Foreground="#1E293B"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,77,-10,45" BorderBrush="#E2E8F0" BorderThickness="1" Grid.RowSpan="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="📊 Данные шага / Параметры" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>

                            <Grid Grid.Row="1" Height="133" VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Text="Фактическое значение:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="0,0,83,0"/>
                                <TextBox x:Name="ActualValueBox" Grid.Row="1" Height="38" 
                                         Style="{StaticResource ModernTextBox}" Margin="11,5,22,61"
                                         PreviewTextInput="NumberValidationTextBox"/>

                                <TextBlock x:Name="NormText" Grid.Column="1" Text="Норма: 75-85" 
                                           Foreground="#64748B" VerticalAlignment="Top" FontSize="12" Margin="10,16,76,0" Grid.Row="1" Grid.ColumnSpan="2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Длительность (мин):" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Top" Margin="0,52,0,0"/>
                                <TextBox x:Name="DurationBox" Grid.Row="1" Height="38" 
                                         Style="{StaticResource ModernTextBox}" Margin="10,73,22,-7"
                                         PreviewTextInput="NumberValidationTextBox"/>

                                <TextBlock x:Name="DurationNormText" Grid.Row="1" Grid.Column="1" Text="Норма: 45 мин" 
                                           Foreground="#64748B" VerticalAlignment="Top" FontSize="12" Margin="12,88,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0"/>

                    <Border x:Name="DeviationWarning" Grid.Row="4" Background="#FEF2F2" CornerRadius="10" Padding="12" Margin="0,15,0,0"
                            BorderBrush="#EF4444" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="DeviationMessage" Text="Отклонение от нормы!" FontSize="13" Foreground="#EF4444" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Button x:Name="StartStepButton" Content="▶ Начать шаг" 
                                Style="{StaticResource SuccessButton}" Click="StartStep_Click" FontSize="13" Grid.Column="1" Margin="137,380,177,10"/>
            <Button x:Name="CompleteStepButton" Content="✓ Завершить шаг" Margin="273,380,21,10"
                                Style="{StaticResource PrimaryButton}" Click="CompleteStep_Click" FontSize="13" IsEnabled="False" Grid.Column="1"/>
        </Grid>
    </Grid>
</UserControl>