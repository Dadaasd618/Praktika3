<UserControl x:Class="OperatorModule.Views.ExtruderLiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#3B82F6" CornerRadius="12" Padding="15,12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Экструдер LIVE" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Партия:" Foreground="#BFDBFE" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="BatchCombo" Width="200" Height="32" 
                              Style="{StaticResource ModernComboBox}" 
                              SelectionChanged="BatchCombo_SelectionChanged"
                              DisplayMemberPath="BatchNumber" SelectedValuePath="Id"/>
                    <Button Content="🔄" Width="45" Height="40" Margin="10,0,0,0"
                            Style="{StaticResource SecondaryButton}" Click="Refresh_Click" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Температурные зоны -->
                <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🌡️ Температура по зонам" FontSize="16" FontWeight="Bold" 
                                   Foreground="#1E293B" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="TemperatureZones">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" 
                                            Background="{Binding StatusColor}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ZoneName}" FontWeight="SemiBold" 
                                                       Foreground="#1E293B"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="Факт: " Foreground="#64748B"/>
                                                <TextBlock Text="{Binding ActualValue}" FontWeight="Bold" 
                                                           Foreground="{Binding ValueColor}"/>
                                                <TextBlock Text="°C" Foreground="#64748B" Margin="5,0,15,0"/>
                                                <TextBlock Text="Норма: " Foreground="#64748B"/>
                                                <TextBlock Text="{Binding PlannedRange}" 
                                                           Foreground="{Binding NormalColor}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                    Background="{Binding StatusColor}"
                                                    BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"
                                                           Foreground="{Binding StatusTextColor}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Давление и параметры -->
                <Border Background="#F8FAFC" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <TextBlock Text="⚙️ Давление и параметры" FontSize="16" FontWeight="Bold" 
                                   Foreground="#1E293B" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="PressureParameters">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" 
                                            Background="{Binding StatusColor}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ParameterName}" FontWeight="SemiBold" 
                                                       Foreground="#1E293B"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="Факт: " Foreground="#64748B"/>
                                                <TextBlock Text="{Binding ActualValue}" FontWeight="Bold" 
                                                           Foreground="{Binding ValueColor}"/>
                                                <TextBlock Text="{Binding Unit}" Foreground="#64748B" Margin="5,0,15,0"/>
                                                <TextBlock Text="Норма: " Foreground="#64748B"/>
                                                <TextBlock Text="{Binding PlannedRange}" 
                                                           Foreground="{Binding NormalColor}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                    Background="{Binding StatusColor}"
                                                    BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                                <TextBlock Text="{Binding Status}" FontSize="10" 
                                                           FontWeight="SemiBold" HorizontalAlignment="Center"
                                                           Foreground="{Binding StatusTextColor}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>