<UserControl x:Class="TechnologistModule.Controls.ProductsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="📦 Управление продукцией" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="#1E293B"/>
            <Button Grid.Column="1" Content="➕ Новый продукт" Width="140" Height="35" 
                    Background="#3B82F6" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    
                    Click="NewProduct_Click"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Height="35" TextChanged="SearchBox_TextChanged"/>
                <ComboBox x:Name="TypeFilter" Grid.Column="1" Width="130" Height="35" Margin="10,0,0,0"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все типы" IsSelected="True"/>
                    <ComboBoxItem Content="Гербицид"/>
                    <ComboBoxItem Content="Инсектицид"/>
                    <ComboBoxItem Content="Фунгицид"/>
                    <ComboBoxItem Content="Регулятор роста"/>
                    <ComboBoxItem Content="Протравитель"/>
                </ComboBox>
                <ComboBox x:Name="StatusFilter" Grid.Column="2" Width="120" Height="35" Margin="10,0,0,0"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="active"/>
                    <ComboBoxItem Content="archived"/>
                </ComboBox>
            </Grid>
        </Border>

        <DataGrid x:Name="ProductsGrid" Grid.Row="2" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                 
                  RowHeight="45"
                  FontSize="13"
                  Background="White"
                  AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="100" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                <DataGridTextColumn Header="Форма выпуска" Binding="{Binding Form}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Действующая рецептура" Binding="{Binding ActiveRecipeVersion}" Width="140"/>
                <DataGridTextColumn Header="Действующая техкарта" Binding="{Binding ActiveTechCardVersion}" Width="140"/>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️" ToolTip="Редактировать" 
                        Click="EditProduct_Click"  Tag="{Binding}" 
                        Width="32" Height="32" Background="Transparent" Foreground="#3B82F6"
                        BorderThickness="0" Cursor="Hand" Margin="2"
                        ClickMode="Press"/>
                                <Button Content="🗑️" ToolTip="Архивировать" 
                        Click="ArchiveProduct_Click" Tag="{Binding}" 
                        Width="32" Height="32" Background="Transparent" Foreground="#EF4444"
                        BorderThickness="0" Cursor="Hand" Margin="2"
                        ClickMode="Press"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>