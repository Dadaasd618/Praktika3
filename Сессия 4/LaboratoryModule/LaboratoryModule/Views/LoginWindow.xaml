<Window x:Class="LaboratoryModule.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LaboratoryModule.Converters"
        Title="АгроКонтроль - Лаборатория" Height="757" Width="544"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow" ShadowDepth="0" BlurRadius="20" Opacity="0.2"/>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563EB" Offset="0"/>
            <GradientStop Color="#3B82F6" Offset="0.5"/>
            <GradientStop Color="#2563EB" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid>
        <Border Width="500" Background="White" CornerRadius="20" Effect="{StaticResource DropShadow}" Margin="20,50,20,10">
            <Grid>
                <!-- Заголовок -->
                <Border Height="100" CornerRadius="20,20,0,0" Background="{StaticResource HeaderGradient}" Margin="0,0,0,597">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔬 АгроКонтроль" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Лабораторный модуль" FontSize="14" Foreground="#BFDBFE" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="40,120,40,30" VerticalAlignment="Top">
                    <!-- Вкладки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <Border x:Name="LoginTabBorder" CornerRadius="20" Background="#3B82F6" Padding="0">
                            <RadioButton x:Name="LoginTab" Content="Вход" IsChecked="True" 
                                         Foreground="White" FontSize="15" FontWeight="SemiBold"
                                         Padding="25,10" GroupName="AuthTab" Background="Transparent"
                                         BorderThickness="0"/>
                        </Border>
                        <Border x:Name="RegisterTabBorder" CornerRadius="20" Background="Transparent" BorderThickness="1" BorderBrush="#CBD5E1" Margin="10,0,0,0">
                            <RadioButton x:Name="RegisterTab" Content="Регистрация" 
                                         Foreground="#1E293B" FontSize="15" FontWeight="SemiBold"
                                         Padding="25,10" GroupName="AuthTab" Background="Transparent"
                                         BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <!-- Панель Входа (без прокрутки) -->
                    <StackPanel x:Name="LoginPanel" Margin="0,0,0,0">
                        <TextBlock Text="Логин" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <TextBox x:Name="LoginUsernameBox" Height="42" Style="{StaticResource ModernTextBox}" 
                                 Margin="0,0,0,20" FontSize="14" BorderBrush="#E2E8F0"/>

                        <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="LoginPasswordBox" Height="42" Style="{StaticResource ModernPasswordBox}" 
                                     Margin="0,0,0,20" FontSize="14" BorderBrush="#E2E8F0"/>

                        <!-- CAPTCHA -->
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,10,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Image x:Name="CaptchaImage" Grid.Row="0" Grid.Column="0" 
                                       Height="65" Stretch="Fill" Margin="0,0,15,0" Cursor="Hand"
                                       MouseDown="RefreshCaptcha_Click" VerticalAlignment="Center"/>

                                <Button Grid.Row="0" Grid.Column="1" Content="🔄" Width="50" Height="50" 
                                        Style="{StaticResource SecondaryButton}" 
                                        Click="RefreshCaptchaButton_Click" FontSize="18"/>

                                <TextBox x:Name="CaptchaCodeBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                         Height="38" Margin="0,12,0,0" Style="{StaticResource ModernTextBox}"
                                         ToolTip="Введите код с картинки" FontSize="14" BorderBrush="#E2E8F0"/>
                            </Grid>
                        </Border>

                        <Button x:Name="ActionButton" Content="ВОЙТИ" Height="46" 
                                Style="{StaticResource PrimaryButton}" Click="ActionButton_Click" 
                                FontSize="16" FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Панель Регистрации (с прокруткой) -->
                    <ScrollViewer x:Name="RegisterPanel" Visibility="Collapsed" MaxHeight="280" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Логин" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <TextBox x:Name="RegUsernameBox" Height="42" Style="{StaticResource ModernTextBox}" 
                                     Margin="0,0,0,15" FontSize="14" BorderBrush="#E2E8F0"/>

                            <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="RegPasswordBox" Height="42" Style="{StaticResource ModernPasswordBox}" 
                                         Margin="0,0,0,15" FontSize="14" BorderBrush="#E2E8F0"/>

                            <TextBlock Text="ФИО" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <TextBox x:Name="RegFullNameBox" Height="42" Style="{StaticResource ModernTextBox}" 
                                     Margin="0,0,0,15" FontSize="14" BorderBrush="#E2E8F0"/>

                            <TextBlock Text="Роль" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <ComboBox x:Name="RegRoleBox" Height="42" Style="{StaticResource ModernComboBox}" 
                                      Margin="0,0,0,15" FontSize="14" BorderBrush="#E2E8F0">
                                <ComboBoxItem Content="laboratory" IsSelected="True"/>
                                <ComboBoxItem Content="technologist"/>
                                <ComboBoxItem Content="operator"/>
                            </ComboBox>

                            <TextBlock Text="Подразделение" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                            <TextBox x:Name="RegDepartmentBox" Height="42" Style="{StaticResource ModernTextBox}" 
                                     Margin="0,0,0,15" FontSize="14" BorderBrush="#E2E8F0"/>

                            <!-- CAPTCHA для регистрации -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="15" Margin="0,10,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Image x:Name="RegCaptchaImage" Grid.Row="0" Grid.Column="0" 
                                           Height="65" Stretch="Fill" Margin="0,0,15,0" Cursor="Hand"
                                           MouseDown="RefreshRegCaptcha_Click" VerticalAlignment="Center"/>

                                    <Button Grid.Row="0" Grid.Column="1" Content="🔄" Width="50" Height="50" 
                                            Style="{StaticResource SecondaryButton}" 
                                            Click="RefreshRegCaptchaButton_Click" FontSize="18"/>

                                    <TextBox x:Name="RegCaptchaCodeBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                             Height="38" Margin="0,12,0,0" Style="{StaticResource ModernTextBox}"
                                             ToolTip="Введите код с картинки" FontSize="14" BorderBrush="#E2E8F0"/>
                                </Grid>
                            </Border>

                            <Button x:Name="RegisterActionButton" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Height="46" 
                                    Style="{StaticResource PrimaryButton}" Click="RegisterActionButton_Click" 
                                    FontSize="16" FontWeight="SemiBold" Margin="0,5,0,20"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Ошибка -->
                    <TextBlock x:Name="ErrorText" Text="" Foreground="#EF4444" FontSize="12" 
                               HorizontalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,10,0,0"/>

                    <TextBlock Text="Версия 1.0.0" FontSize="11" Foreground="#94A3B8" 
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>