<Window x:Class="OperatorModule.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Вход"
        Height="450" 
        Width="397"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="C:\Users\User\Desktop\Учебная практика(3)\app.ico">

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow" ShadowDepth="0" BlurRadius="20" Opacity="0.2"/>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563EB" Offset="0"/>
            <GradientStop Color="#3B82F6" Offset="0.5"/>
            <GradientStop Color="#2563EB" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Margin="0,0,10,11">
        <Border Width="440" Background="White" CornerRadius="20" Effect="{StaticResource DropShadow}" Margin="6,20,5,0">
            <Grid Margin="0,0,0,-24">
                <Border Height="100" CornerRadius="20,20,0,0" Background="{StaticResource HeaderGradient}" Margin="0,0,63,327">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🏭 АгроКонтроль" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Модуль аппаратчика" FontSize="14" Foreground="#BFDBFE" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="40,120,40,30" VerticalAlignment="Top">
                    <TextBlock Text="Логин" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameBox" Height="42" Style="{StaticResource ModernTextBox}" 
                             Margin="0,0,0,20" FontSize="14" BorderBrush="#E2E8F0"/>

                    <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox" Height="42" Style="{StaticResource ModernPasswordBox}" 
                                 Margin="0,0,0,25" FontSize="14" BorderBrush="#E2E8F0"/>

                    <Button x:Name="LoginButton" Content="ВОЙТИ" Height="46" 
                            Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" 
                            FontSize="16" FontWeight="SemiBold"/>

                    <TextBlock x:Name="ErrorText" Text="" Foreground="#EF4444" FontSize="12" 
                               HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,10,0,0" TextWrapping="Wrap"/>

                    <TextBlock Text="Версия 1.0.0" FontSize="11" Foreground="#94A3B8" 
                               HorizontalAlignment="Center" Margin="0,25,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>