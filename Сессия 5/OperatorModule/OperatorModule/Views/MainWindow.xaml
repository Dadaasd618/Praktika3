<Window x:Class="OperatorModule.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Аппаратчик" 
        Height="720" 
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        Icon="C:\Users\User\Desktop\Учебная практика(3)\app.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#1E293B" CornerRadius="0,20,20,0">
            <StackPanel>
                <!-- Профиль с фото -->
                <Border Background="#0F172A" Padding="20" Margin="0,0,0,25">
                    <StackPanel>
                        <!-- Аватарка -->
                        <Border Width="60" Height="60" Background="#3B82F6" CornerRadius="30" 
                                HorizontalAlignment="Center" Margin="0,0,0,12"
                                Cursor="Hand" MouseLeftButtonDown="Avatar_Click">
                            <Image x:Name="UserAvatar" Width="60" Height="60" 
                                   Stretch="UniformToFill" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="UserFullName" Text="Заводов С.Н." 
                                   FontWeight="Bold" Foreground="White" FontSize="15" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="UserRole" Text="Аппаратчик" 
                                   Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="UserShift" Text="Смена: 2" 
                                   Foreground="#64748B" FontSize="12" HorizontalAlignment="Center"/>

                        <!-- Кнопка уведомлений -->
                        <Button x:Name="NotificationsButton" Click="NotificationsButton_Click" 
                                Margin="0,10,0,0" Height="36" 
                                Background="#3B82F6" BorderThickness="0" 
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🔔" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Уведомления" Foreground="White" FontSize="13"/>
                                <Border x:Name="NotificationBadge" Background="#EF4444" CornerRadius="10" 
                                        Width="20" Height="20" Margin="8,0,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="NotificationCount" Text="0" FontSize="10" 
                                               Foreground="White" TextAlignment="Center" 
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,0,0,25">
                    <Button x:Name="ActiveBatchesButton" Content="📋 Активные партии" 
                            Style="{StaticResource SideMenuButton}" Click="ActiveBatchesButton_Click" FontSize="14" Height="48"/>
                    <Button x:Name="BatchProgramButton" Content="⚙️ Программа партии" 
                            Style="{StaticResource SideMenuButton}" Click="BatchProgramButton_Click" FontSize="14" Height="48"/>
                    <Button x:Name="ExtruderLiveButton" Content="📊 Экструдер LIVE" 
                            Style="{StaticResource SideMenuButton}" Click="ExtruderLiveButton_Click" FontSize="14" Height="48"/>
                    <Button x:Name="BatchJournalButton" Content="📜 Журнал партии" 
                            Style="{StaticResource SideMenuButton}" Click="BatchJournalButton_Click" FontSize="14" Height="48"/>
                    <Button x:Name="ReportProblemButton" Content="⚠️ Сообщить о проблеме" 
                            Style="{StaticResource SideMenuButton}" Click="ReportProblemButton_Click" FontSize="14" Height="48"/>
                </StackPanel>

                <Button x:Name="LogoutButton" Content="🚪 Выход" 
                        Style="{StaticResource SideMenuButton}" Click="LogoutButton_Click" 
                        FontSize="14" Height="48" Margin="0,50,0,0"/>
            </StackPanel>
        </Border>

        <!-- Область контента -->
        <Border Grid.Column="1" Margin="20" Background="White" CornerRadius="16">
            <ContentControl x:Name="ContentArea" Margin="5"/>
        </Border>
    </Grid>
</Window>