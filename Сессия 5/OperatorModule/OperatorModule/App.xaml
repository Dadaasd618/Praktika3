<Application x:Class="OperatorModule.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Themes/DataGridStyles.xaml"/>
                <ResourceDictionary Source="Themes/TextStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DropShadowEffect x:Key="ContentShadow" ShadowDepth="0" BlurRadius="15" Opacity="0.08"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>