<UserControl x:Class="TechnologistModule.Controls.EventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚠️ Отклонения и события" FontSize="22" FontWeight="Bold" 
                   Foreground="#1E293B" Margin="15,10,0,10"/>

        <TabControl Grid.Row="1" Margin="10,0,10,10">
            <!-- Отклонения -->
            <TabItem Header="Отклонения">
                <DataGrid x:Name="DeviationsGrid" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True" 
                          RowHeight="40" 
                          FontSize="12" 
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Партия" Binding="{Binding BatchNumber}" Width="120"/>
                        <DataGridTextColumn Header="Шаг" Binding="{Binding StepName}" Width="150"/>
                        <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="150"/>
                        <DataGridTextColumn Header="Плановое значение" Binding="{Binding PlannedValue}" Width="130"/>
                        <DataGridTextColumn Header="Фактическое значение" Binding="{Binding ActualValue}" Width="130"/>
                        <DataGridTextColumn Header="Критичность" Binding="{Binding Severity}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- События аудита -->
            <TabItem Header="События аудита">
                <DataGrid x:Name="EventsGrid" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True" 
                          RowHeight="40" 
                          FontSize="12" 
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Тип события" Binding="{Binding EventType}" Width="130"/>
                        <DataGridTextColumn Header="Тип объекта" Binding="{Binding ObjectType}" Width="120"/>
                        <DataGridTextColumn Header="ID объекта" Binding="{Binding ObjectId}" Width="80"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="300"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="150"/>
                        <DataGridTextColumn Header="Кто" Binding="{Binding CreatedBy}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>