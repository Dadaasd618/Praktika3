<UserControl x:Class="OperatorModule.Views.ReportProblemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#EF4444" CornerRadius="12" Padding="15,12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚠️ Сообщить о проблеме" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Срочно!" FontSize="14" FontWeight="Bold" Foreground="#FEE2E2"/>
            </Grid>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📋 Детали проблемы" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Партия:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                    <ComboBox x:Name="BatchCombo" Grid.Column="1" Height="38" Style="{StaticResource ModernComboBox}"
                              SelectionChanged="BatchCombo_SelectionChanged"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Шаг:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StepCombo" Grid.Column="1" Height="38" Style="{StaticResource ModernComboBox}"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Тип проблемы:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ProblemTypeCombo" Grid.Column="1" Height="38" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Отклонение параметра" IsSelected="True"/>
                        <ComboBoxItem Content="Поломка оборудования"/>
                        <ComboBoxItem Content="Шум/вибрация"/>
                        <ComboBoxItem Content="Утечка"/>
                        <ComboBoxItem Content="Сбой программы"/>
                        <ComboBoxItem Content="Другое"/>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="4" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Критичность:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                    <ComboBox x:Name="SeverityCombo" Grid.Column="1" Height="38" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Низкая" Tag="low"/>
                        <ComboBoxItem Content="Средняя" Tag="medium" IsSelected="True"/>
                        <ComboBoxItem Content="Высокая" Tag="high"/>
                        <ComboBoxItem Content="Критическая" Tag="critical"/>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="5" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Описание:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Top" Margin="0,8,0,0"/>
                    <TextBox x:Name="DescriptionBox" Grid.Column="1" Height="80" TextWrapping="Wrap" 
                             Style="{StaticResource ModernTextBox}" VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <TextBlock x:Name="ErrorText" Grid.Row="6" Text="" Foreground="#EF4444" FontSize="12" 
                           Margin="120,0,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>

                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="SubmitButton" Content="📤 Отправить сообщение" Width="180" Height="40" 
                            Style="{StaticResource PrimaryButton}" Click="SubmitProblem_Click" FontSize="13"/>
                </StackPanel>

                <TextBlock x:Name="SuccessText" Grid.Row="8" Text="" Foreground="#10B981" FontSize="13" 
                           Margin="120,10,0,0" Visibility="Collapsed" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>