<Window x:Class="LaboratoryModule.Views.RawMaterialBatchCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LaboratoryModule.Converters"
        Title="Карточка партии сырья" Height="805" Width="864"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Window.Resources>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#3B82F6" CornerRadius="8" Padding="12" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" Text="📦 Карточка партии сырья" FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Основная информация -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <!-- Строка 1 -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Номер партии:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BatchNumberText" Grid.Column="1" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Количество (кг):" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="QuantityText" Grid.Column="3" Foreground="#1E293B" VerticalAlignment="Center"/>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <!-- Строка 2 -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Материал:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="MaterialText" Grid.Column="1" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Статус:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <Border x:Name="StatusBorder" Grid.Column="3" CornerRadius="10" Padding="6,3" Width="85" HorizontalAlignment="Left">
                        <TextBlock x:Name="StatusText" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <!-- Строка 3 -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Категория:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CategoryText" Grid.Column="1" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Место хранения:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StorageText" Grid.Column="3" Foreground="#1E293B" VerticalAlignment="Center"/>
                </Grid>

                <Rectangle Height="1" Fill="#E2E8F0" Margin="0,8"/>

                <!-- Строка 4 -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Поставщик:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SupplierText" Grid.Column="1" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Grid.Column="2" Text="Дата поступления:" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ArrivalDateText" Grid.Column="3" Foreground="#1E293B" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Испытания -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,282" BorderBrush="#E2E8F0" BorderThickness="1" Grid.RowSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="📋 Испытания" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                    <Button Grid.Column="1" Content="🔄" Width="30" Height="30" 
            Style="{StaticResource SecondaryButton}" Click="RefreshTests_Click" ToolTip="Обновить список"/>
                    <Button Grid.Column="2" Content="➕ Новое испытание" Width="130" Height="30" Margin="10,0,0,0"
            Style="{StaticResource PrimaryButton}" Click="NewTest_Click" FontSize="12"/>
                </Grid>

                <DataGrid x:Name="TestsGrid" Grid.Row="1" 
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="TestsGrid_SelectionChanged"
                          MaxHeight="140">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ испытания" Binding="{Binding TestNumber}" Width="100"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding TestType}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Исполнитель" Binding="{Binding TestedByName}" Width="130"/>
                        <DataGridTemplateColumn Header="Статус" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="5,2" 
                                            Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                            Width="75" Height="24" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Лабораторное решение -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,185,0,-20" BorderBrush="#E2E8F0" BorderThickness="1" Grid.RowSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🔬 Лабораторное решение" FontSize="14" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Текущий статус:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="CurrentStatusText" Grid.Column="1" Foreground="#1E293B" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Дата решения:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="DecisionDateText" Grid.Column="3" Foreground="#1E293B"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Принял решение:" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="DecisionByText" Grid.Column="1" Foreground="#1E293B"/>
                </Grid>

                <StackPanel Grid.Row="3" Margin="0,5,0,0">
                    <TextBlock Text="Комментарий / Причина:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                    <TextBox x:Name="DecisionCommentBox" Height="50" TextWrapping="Wrap" IsEnabled="False"
                             Style="{StaticResource ModernTextBox}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Закрыть" Width="100" Height="35" Style="{StaticResource SecondaryButton}" Click="Close_Click"/>
            <Button x:Name="DecisionButton" Content="Принять решение" Width="130" Height="35" Margin="10,0,0,0"
                    Style="{StaticResource PrimaryButton}" Click="MakeDecision_Click"/>
        </StackPanel>
    </Grid>
</Window>